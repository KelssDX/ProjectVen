NODE_ENV=development
HOST=0.0.0.0
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Data stores
DATABASE_URL=postgresql://vendrome:vendrome@localhost:5433/vendrome
VALKEY_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# Search indexing
SEARCH_INDEXING_ENABLED=false
SEARCH_INDEXING_BATCH_SIZE=50
SEARCH_INDEXING_POLL_INTERVAL_MS=5000
SEARCH_INDEXING_CONTINUOUS=false
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PROFILES=vendrome-profiles
OPENSEARCH_INDEX_POSTS=vendrome-posts

# Auth
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Calendar providers
CALENDAR_SYNC_ENABLED=false
CALENDAR_SYNC_BATCH_SIZE=10
CALENDAR_SYNC_POLL_INTERVAL_MS=30000
CALENDAR_SYNC_CONTINUOUS=false
CALENDAR_SYNC_LOOKBACK_DAYS=30
CALENDAR_SYNC_LOOKAHEAD_DAYS=365
CALENDAR_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-secret
CALENDAR_OAUTH_STATE_SECRET=replace-with-state-secret
CALENDAR_WEBHOOK_SECRET=replace-with-webhook-secret
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_WEBHOOK_CALLBACK_URL=
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_TENANT_ID=common
MICROSOFT_CALENDAR_WEBHOOK_CALLBACK_URL=
GOOGLE_CALENDAR_WEBHOOK_SECRET=
MICROSOFT_CALENDAR_WEBHOOK_SECRET=

# Payment gateways
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
YOCO_SECRET_KEY=
PEACH_PAYMENTS_ENTITY_ID=
PEACH_PAYMENTS_ACCESS_TOKEN=
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
